<Window x:Class="Engine.MainWindow"
        xmlns:vm="clr-namespace:Engine.Render.GameUIDataContext"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:troops="clr-namespace:DrwalCraft.Core.Troops;assembly=DrwalCraft.Core"
        xmlns:buildings="clr-namespace:DrwalCraft.Core.Buildings;assembly=DrwalCraft.Core"
        xmlns:army="clr-namespace:DrwalCraft.Core.Army;assembly=DrwalCraft.Core"
        xmlns:core="clr-namespace:DrwalCraft.Core;assembly=DrwalCraft.Core"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Title="DrwalCraft" Height="450" Width="800">
    
    <Window.Resources>
        <DataTemplate x:Key="GameObjectTemplate">
            <StackPanel>                
                <TextBlock FontSize="32"
                    Foreground="White">
                    <TextBlock.Text>
                        <Binding Path="Name" />
                    </TextBlock.Text>  
                </TextBlock>
                <TextBlock FontSize="24"
                    Foreground="White">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hp: {0} / {1}">
                            <Binding Path="Hp" />
                            <Binding Path="MaxHp" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="TroopInArmy">
                <TextBlock FontSize="16"
                    Foreground="White">
                    <TextBlock.Text>
                        <MultiBinding StringFormat=" {0}: {1} / {2}">
                            <Binding Path="Name"/>
                            <Binding Path="Hp" />
                            <Binding Path="MaxHp" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
        </DataTemplate>
        <DataTemplate DataType="{x:Type troops:Troop}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type buildings:Building}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type army:Army}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
                <ItemsControl Background="#222"
                    ItemsSource="{Binding Troops}"
                    ItemTemplate="{StaticResource TroopInArmy}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type core:Tree}">
            <StackPanel>
                <TextBlock FontSize="32"
                    Foreground="White"
                    Text="Tree"
                    TextWrapping="Wrap"/>
                <TextBlock FontSize="16"
                    Foreground="White"
                    Text="Unfortunatly it's made of plastic. Therefore cutting it down won't help you"
                    TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Window.DataContext>
        <vm:GameUIDataContext/>
    </Window.DataContext>

    <Grid Background="#222">
        <!-- GŁÓWNY PODZIAŁ: MENU | MAPA -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= MENU ================= -->
        <Grid Grid.Column="0"
            Background="#222">

            <!-- MINIMAPA (GÓRA) + RESZTA MENU (DÓŁ) -->
            <Grid.RowDefinitions>
                <RowDefinition Height="272"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- MINIMAPA -->
            <Border Grid.Row="0"
                    Margin="7"
                    BorderThickness="1"
                    BorderBrush="#555">
                <Image x:Name="MiniMapImage"
                    Stretch="Uniform"
                    Width="256"
                    Height="256"/>
            </Border>

            <!-- PANEL MENU / INFO O ZAZNACZONYM OBIEKCIE -->
            <StackPanel Grid.Row="1"
                        Margin="8"
                        Orientation="Vertical">
                <ContentControl Content="{Binding ActiveUnit}"/>
            </StackPanel>
        </Grid>

        <!-- ================= MAPA GRY ================= -->
        <Grid x:Name="GameMapGrid"
            Grid.Column="1"
            Background="#3A7F3A"
            ClipToBounds="True">
            <Image x:Name="GameMapImage"
                Stretch="Fill"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseWheel="MainMapMouseWheel"/>
            <Canvas>
                <Rectangle
                    x:Name="MainMapSelectionBox"
                    Visibility="Collapsed"
                    Stroke="#00FF00"
                    Fill="#1000FF00"
                    StrokeThickness="1"
                    />
            </Canvas>
        </Grid>

</Grid>

</Window>
