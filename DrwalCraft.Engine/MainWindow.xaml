<Window x:Class="DrwalCraft.Engine.MainWindow"
        xmlns:vm="clr-namespace:DrwalCraft.Engine.Render.GameUIDataContext"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:troops="clr-namespace:DrwalCraft.Core.Troops;assembly=DrwalCraft.Core"
        xmlns:buildings="clr-namespace:DrwalCraft.Core.Buildings;assembly=DrwalCraft.Core"
        xmlns:army="clr-namespace:DrwalCraft.Core.Army;assembly=DrwalCraft.Core"
        xmlns:core="clr-namespace:DrwalCraft.Core;assembly=DrwalCraft.Core"
        xmlns:mines="clr-namespace:DrwalCraft.Core.Mines;assembly=DrwalCraft.Core"
        xmlns:trees="clr-namespace:DrwalCraft.Core.Trees;assembly=DrwalCraft.Core"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Title="DrwalCraft" Height="450" Width="800">
    
    <Window.Resources>
        <DataTemplate x:Key="GameObjectTemplate">
            <StackPanel>                
                <TextBlock FontSize="32"
                    Foreground="White">
                    <TextBlock.Text>
                        <Binding Path="Name" />
                    </TextBlock.Text>  
                </TextBlock>
                <TextBlock FontSize="24"
                    Foreground="White">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hp: {0} / {1}">
                            <Binding Path="Hp" />
                            <Binding Path="MaxHp" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="TroopInArmy">
                <TextBlock FontSize="16"
                    Foreground="White">
                    <TextBlock.Text>
                        <MultiBinding StringFormat=" {0}: {1} / {2}">
                            <Binding Path="Name"/>
                            <Binding Path="Hp"/>
                            <Binding Path="MaxHp" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
        </DataTemplate>
        <DataTemplate x:Key="Products">
            <StackPanel>
                <TextBlock FontSize="24" Foreground="White" Text="Produce:" />
                <ItemsControl
                    FontSize="16"
                    Foreground="White"
                    Background="#222"
                    ItemsSource="{Binding Products}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                            Click="OnProduceClick" 
                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            Margin="5"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="Pricing">
            <StackPanel>
                <TextBlock FontSize="20" Foreground="White" Text="Pricing:" />
                <ItemsControl
                    FontSize="16"
                    Foreground="White"
                    Background="#222"
                    ItemsSource="{Binding Pricing}">
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="BarrackInProduction">
            <StackPanel>
                <TextBlock FontSize="24" Foreground="White" >
                    <TextBlock.Text>
                        <Binding StringFormat="Producing: {0}" Path="Producing.Name"/>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock FontSize="24" Foreground="White" >
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Progress: {0}/{1}">
                            <Binding Path="Progress"/>
                            <Binding Path="ProductionTime"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type troops:Troop}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
                <TextBlock FontSize="24"
                    Foreground="White">
                    <TextBlock.Text>
                        <MultiBinding StringFormat=" Damage: {0}">
                            <Binding Path="Damage"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type troops:Builder}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource Pricing}" />
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate" Value="{StaticResource Products}" />
                            
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Constructing}" Value="True">
                                    <Setter Property="ContentTemplate" Value="{StaticResource BarrackInProduction}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type buildings:Building}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource Pricing}" />
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate" Value="{StaticResource Products}" />
                            
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding InProduction}" Value="True">
                                    <Setter Property="ContentTemplate" Value="{StaticResource BarrackInProduction}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type mines:Mine}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
                <StackPanel>
                    <TextBlock FontSize="24" Foreground="White" Text="Miners:" />
                    <ItemsControl
                        FontSize="16"
                        Foreground="White"
                        Background="#222"
                        ItemsSource="{Binding Miners}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Name="Name">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat=" {0}: {1}/{2}">
                                            <Binding Path="Name"/>
                                            <Binding Path="Hp"/>
                                            <Binding Path="MaxHp"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type army:Army}">
            <StackPanel>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource GameObjectTemplate}" />
                <ItemsControl Background="#222"
                    ItemsSource="{Binding Troops}"
                    ItemTemplate="{StaticResource TroopInArmy}" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate DataType="{x:Type trees:Tree}">
            <StackPanel>
                <TextBlock FontSize="32"
                    Foreground="White"
                    Text="Tree"
                    TextWrapping="Wrap"/>
                <TextBlock FontSize="16"
                    Foreground="White"
                    Text="Unfortunatly it's made of plastic. Therefore cutting it down won't help you"
                    TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Window.DataContext>
        <vm:GameUIDataContext/>
    </Window.DataContext>

    <Grid Background="#222">
        <!-- GŁÓWNY PODZIAŁ: MENU | MAPA -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= MENU ================= -->
        <Grid Grid.Column="0"
            Background="#222">

            <!-- MINIMAPA (GÓRA) + RESZTA MENU (DÓŁ) -->
            <Grid.RowDefinitions>
                <RowDefinition Height="272"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- MINIMAPA -->
            <Border Grid.Row="0"
                    Margin="7"
                    BorderThickness="1"
                    BorderBrush="#555">
                <Image x:Name="MiniMapImage"
                    Stretch="Uniform"
                    Width="256"
                    Height="256"/>
            </Border>

            <!-- PANEL MENU / INFO O ZAZNACZONYM OBIEKCIE -->
            <StackPanel Grid.Row="1"
                        Margin="8"
                        Orientation="Vertical">
                <TextBlock FontSize="24" Foreground="White" >
                    <TextBlock.Text>
                        <Binding StringFormat="Wood: {0}" Path="Wood"/>
                    </TextBlock.Text>
                </TextBlock>
                <Separator Margin="0,10"/>
                <TextBlock FontSize="32" Foreground="White" Text="Active Object:"/>
                <ContentControl Content="{Binding ActiveUnit}"/>
            </StackPanel>
        </Grid>

        <!-- ================= MAPA GRY ================= -->
        <Grid x:Name="GameMapGrid"
            Grid.Column="1"
            Background="#3A7F3A"
            ClipToBounds="True">
            <Image x:Name="GameMapImage"
                Stretch="Fill"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                MouseWheel="MainMapMouseWheel"/>
            <Canvas>
                <Rectangle
                    x:Name="MainMapSelectionBox"
                    Visibility="Collapsed"
                    Stroke="#00FF00"
                    Fill="#1000FF00"
                    StrokeThickness="1"
                    />
            </Canvas>
        </Grid>

</Grid>

</Window>
